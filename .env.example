# Create this key in https://resend.com/api-keys
RESEND_API_KEY=re_replace_with_your_key

# Destination mailbox for website requests. Configure privately in the deployment environment.
CONTACT_TO_EMAIL=recipient@example.com

# Must use a sender address on a domain verified in Resend.
CONTACT_FROM_EMAIL="VANTAM Website <website@updates.your-domain.com>"
