# Server-only Supabase project URL.
SUPABASE_URL=https://your-project.supabase.co

# Server-only Supabase secret key. Never use a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY=sb_secret_replace_with_your_server_key

# Generate a long random value and configure it only in the deployment environment.
CONTACT_RATE_LIMIT_SECRET=replace_with_at_least_32_random_characters

# Comma-separated exact origins. Wildcards are not supported.
CONTACT_ALLOWED_ORIGINS=https://www.vantam.xyz

# Withdrawal requests use their own server-side abuse controls.
WITHDRAWAL_RATE_LIMIT_SECRET=replace_with_at_least_32_random_characters
WITHDRAWAL_ALLOWED_ORIGINS=https://www.vantam.xyz

# Gmail API OAuth 2.0 for acknowledgement mail only.
# Use an installed-app or web OAuth client, enable the Gmail API, and store the refresh token from the consented account.
GOOGLE_CLIENT_ID=replace_with_your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_your_google_oauth_client_secret
GOOGLE_REFRESH_TOKEN=replace_with_a_google_refresh_token
GMAIL_SENDER_ADDRESS=replace_with_the_monitored_gmail_address
